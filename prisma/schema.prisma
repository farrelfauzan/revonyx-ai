generator client {
  provider        = "prisma-client"
  output          = "../apps/api/src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  balance       Decimal        @default(0) @db.Decimal(12, 6)
  apiKey        String         @unique @default(uuid())
  createdAt     DateTime       @default(now()) @db.Timestamptz()
  usageLogs     UsageLog[]
  transactions  Transaction[]
  conversations Conversation[]
  knowledgeBases KnowledgeBase[]
  portalSessions PortalSession[]
  memories      UserMemory[]
  agents        Agent[]
  agentSubscription AgentSubscription?
  channels      Channel[]
  ownedWorkspaces    Workspace[]        @relation("WorkspaceOwner")
  workspaceMemberships WorkspaceMember[]
  workspaceInvitesSent WorkspaceInvite[] @relation("InviteSender")

  @@map("users")
}

model UsageLog {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  model        String
  inputTokens  Int
  outputTokens Int
  cost         Decimal  @db.Decimal(12, 6)
  latencyMs    Int
  provider     String
  createdAt    DateTime @default(now()) @db.Timestamptz()

  @@index([userId])
  @@index([createdAt])

  @@map("usage_logs")
}

model Transaction {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  amount    Decimal  @db.Decimal(12, 6)
  type      String   // "topup" | "deduction" | "refund"
  status    String   // "pending" | "success" | "failed"
  reference String?  @unique // Stripe/Xendit payment ID
  createdAt DateTime @default(now()) @db.Timestamptz()

  @@index([userId])
  @@index([createdAt])

  @@map("transactions")
}

model AiModel {
  id          String   @id @default(uuid())
  slug        String   @unique
  modelName   String   @map("model_name")
  provider    String
  providerId  String
  inputPrice  Decimal  @db.Decimal(18, 12)
  outputPrice Decimal  @db.Decimal(18, 12)
  maxTokens   Int
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @db.Timestamptz()
  updatedAt   DateTime @updatedAt @db.Timestamptz()

  @@map("ai_models")
}

model AppConfig {
  id    String @id @default(uuid())
  key   String @unique
  value String

  @@map("app_configs")
}

model SystemPrompt {
  id        String   @id @default(uuid())
  name      String   @unique
  content   String
  active    Boolean  @default(true)
  priority  Int      @default(0)
  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()

  @@index([active])
  @@map("system_prompts")
}

model PromptTemplate {
  id           String   @id @default(uuid())
  slug         String   @unique
  name         String
  description  String
  content      String
  keywords     String[] // keywords used for intent matching
  active       Boolean  @default(true)
  priority     Int      @default(0)
  outputFormat String?  @map("output_format") // "pdf" | "docx" | "xlsx" | null
  createdAt    DateTime @default(now()) @db.Timestamptz()
  updatedAt    DateTime @updatedAt @db.Timestamptz()

  @@index([active])
  @@map("prompt_templates")
}

model Conversation {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  title     String?
  model     String
  createdAt DateTime  @default(now()) @db.Timestamptz()
  updatedAt DateTime  @updatedAt @db.Timestamptz()
  messages  Message[]

  @@index([userId])
  @@index([updatedAt])
  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String       // "user" | "assistant" | "system"
  content        String
  documentFormat String?      @map("document_format")
  documentFilename String?    @map("document_filename")
  documentKey    String?      @map("document_key")
  createdAt      DateTime     @default(now()) @db.Timestamptz()

  @@index([conversationId])
  @@map("messages")
}

model KnowledgeBase {
  id          String           @id @default(uuid())
  userId      String?
  user        User?            @relation(fields: [userId], references: [id])
  workspaceId String?          @map("workspace_id")
  workspace   Workspace?       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  description String?
  isSystem    Boolean          @default(false) @map("is_system")
  active      Boolean          @default(true)
  createdAt   DateTime         @default(now()) @db.Timestamptz()
  updatedAt   DateTime         @updatedAt @db.Timestamptz()
  chunks      KnowledgeChunk[]
  agentKnowledgeBases AgentKnowledgeBase[]

  @@index([userId])
  @@index([workspaceId])
  @@map("knowledge_bases")
}

model KnowledgeChunk {
  id              String        @id @default(uuid())
  knowledgeBaseId String
  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  content         String
  metadata        Json?
  embedding       Unsupported("vector(1024)")?
  tokenCount      Int
  createdAt       DateTime      @default(now()) @db.Timestamptz()

  @@index([knowledgeBaseId])
  @@map("knowledge_chunks")
}

model PortalSession {
  id            String    @id @default(uuid())
  sessionToken  String    @unique
  requestCount  Int       @default(0)
  ipAddress     String?
  userId        String?
  user          User?     @relation(fields: [userId], references: [id])
  lastRequestAt DateTime? @db.Timestamptz()
  lastResetAt   DateTime  @default(now()) @db.Timestamptz()
  createdAt     DateTime  @default(now()) @db.Timestamptz()

  @@index([userId])
  @@index([lastResetAt])
  @@index([ipAddress])
  @@map("portal_sessions")
}

model UserMemory {
  id                   String    @id @default(uuid())
  userId               String
  user                 User      @relation(fields: [userId], references: [id])
  type                 String    // "interest" | "preference" | "context" | "exclusion"
  content              String
  confidence           Float     @default(0.75)
  sourceMessageId      String?   @map("source_message_id")
  sourceConversationId String?   @map("source_conversation_id")
  lastConfirmedAt      DateTime  @default(now()) @db.Timestamptz()
  expiresAt            DateTime? @db.Timestamptz()
  isUserPinned         Boolean   @default(false) @map("is_user_pinned")
  status               String    @default("active") // "active" | "archived" | "deleted"
  createdAt            DateTime  @default(now()) @db.Timestamptz()
  updatedAt            DateTime  @updatedAt @db.Timestamptz()

  @@index([userId, status])
  @@index([userId, type])
  @@map("user_memories")
}

// ─── AI Agent Portal Models ─────────────────────────────────────────────────────

model Agent {
  id              String          @id @default(uuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id])
  parentAgentId   String?         @map("parent_agent_id")
  parentAgent     Agent?          @relation("SubAgents", fields: [parentAgentId], references: [id], onDelete: SetNull)
  subAgents       Agent[]         @relation("SubAgents")
  workspaceId     String?         @map("workspace_id")
  workspace       Workspace?      @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  name            String
  slug            String
  description     String?
  avatar          String?
  avatarColor     String?         @default("#6366f1") @map("avatar_color")
  systemPrompt    String          @map("system_prompt")
  model           String
  temperature     Float           @default(0.7)
  maxTokens       Int?            @map("max_tokens")
  status          String          @default("draft") // "draft" | "active" | "archived"
  isPublic        Boolean         @default(false) @map("is_public")
  agentType       String          @default("standalone") @map("agent_type") // "standalone" | "parent" | "sub_agent"
  tools           AgentTool[]
  integrations    AgentIntegration[]
  knowledgeBases  AgentKnowledgeBase[]
  channels        AgentChannel[]
  runs            AgentRun[]
  channelAgents   ChannelAgent[]
  createdAt       DateTime        @default(now()) @db.Timestamptz()
  updatedAt       DateTime        @updatedAt @db.Timestamptz()

  @@unique([userId, slug])
  @@index([userId, status])
  @@index([parentAgentId])
  @@index([isPublic])
  @@index([workspaceId, status])
  @@map("agents")
}

model AgentIntegration {
  id              String   @id @default(uuid())
  agentId         String
  agent           Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  provider        String   // "jira" | "plane" | "google_calendar" | "outlook" | "notion" | "slack" | "github"
  config          Json     // { baseUrl, apiKey (encrypted), projectId, etc. }
  scopes          String[] // permitted actions
  status          String   @default("connected") // "connected" | "expired" | "revoked"
  createdAt       DateTime @default(now()) @db.Timestamptz()
  updatedAt       DateTime @updatedAt @db.Timestamptz()

  @@unique([agentId, provider])
  @@index([agentId])
  @@map("agent_integrations")
}

model AgentTool {
  id        String   @id @default(uuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  toolType  String   @map("tool_type") // "web_search" | "calculator" | "code_exec" | "api_call" | "knowledge_retrieval"
  config    Json?
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz()

  @@index([agentId])
  @@map("agent_tools")
}

model AgentKnowledgeBase {
  id              String        @id @default(uuid())
  agentId         String
  agent           Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  knowledgeBaseId String        @map("knowledge_base_id")
  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id])
  createdAt       DateTime      @default(now()) @db.Timestamptz()

  @@unique([agentId, knowledgeBaseId])
  @@map("agent_knowledge_bases")
}

model AgentChannel {
  id          String   @id @default(uuid())
  agentId     String
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  channelType String   @map("channel_type") // "web" | "whatsapp" | "api"
  config      Json?
  status      String   @default("active") // "active" | "paused" | "disconnected"
  createdAt   DateTime @default(now()) @db.Timestamptz()
  updatedAt   DateTime @updatedAt @db.Timestamptz()

  @@unique([agentId, channelType])
  @@index([channelType, status])
  @@map("agent_channels")
}

model AgentRun {
  id             String          @id @default(uuid())
  agentId        String
  agent          Agent           @relation(fields: [agentId], references: [id], onDelete: Cascade)
  sessionId      String          @map("session_id")
  channelType    String          @map("channel_type") // "web" | "whatsapp" | "api"
  externalUserId String?         @map("external_user_id")
  status         String          @default("active") // "active" | "completed" | "error"
  messages       AgentMessage[]
  metadata       Json?
  createdAt      DateTime        @default(now()) @db.Timestamptz()
  updatedAt      DateTime        @updatedAt @db.Timestamptz()

  @@index([agentId])
  @@index([sessionId])
  @@index([externalUserId])
  @@map("agent_runs")
}

model AgentMessage {
  id         String   @id @default(uuid())
  runId      String   @map("run_id")
  run        AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  role       String   // "user" | "assistant" | "system" | "tool"
  content    String
  toolCalls  Json?    @map("tool_calls")
  toolResult Json?    @map("tool_result")
  tokens     Int?
  cost       Decimal? @db.Decimal(12, 6)
  createdAt  DateTime @default(now()) @db.Timestamptz()

  @@index([runId])
  @@map("agent_messages")
}

model AgentSubscription {
  id                 String   @id @default(uuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id])
  tier               String   // "starter" | "pro" | "enterprise"
  maxWorkspaceUsers  Int?     @map("max_workspace_users")
  status             String   @default("active") // "active" | "canceled" | "past_due" | "expired"
  currentPeriodStart DateTime @map("current_period_start") @db.Timestamptz()
  currentPeriodEnd   DateTime @map("current_period_end") @db.Timestamptz()
  messagesUsed       Int      @default(0) @map("messages_used")
  cancelAtPeriodEnd  Boolean  @default(false) @map("cancel_at_period_end")
  createdAt          DateTime @default(now()) @db.Timestamptz()
  updatedAt          DateTime @updatedAt @db.Timestamptz()

  @@index([userId, status])
  @@map("agent_subscriptions")
}

// ─── Channels System (Discord-like) ───

model Channel {
  id        String         @id @default(uuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  name      String
  icon      String?
  color     String?        @default("#6366f1")
  agents    ChannelAgent[]
  rooms     ChannelChatRoom[]
  workspace Workspace?
  createdAt DateTime       @default(now()) @db.Timestamptz()
  updatedAt DateTime       @updatedAt @db.Timestamptz()

  @@index([userId])
  @@map("channels")
}

model ChannelAgent {
  id        String           @id @default(uuid())
  channelId String           @map("channel_id")
  channel   Channel          @relation(fields: [channelId], references: [id], onDelete: Cascade)
  agentId   String           @map("agent_id")
  agent     Agent            @relation(fields: [agentId], references: [id], onDelete: Cascade)
  role      String           @default("primary") // "primary" | "sub"
  createdAt DateTime         @default(now()) @db.Timestamptz()

  @@unique([channelId, agentId])
  @@index([channelId])
  @@index([agentId])
  @@map("channel_agents")
}

model ChannelChatRoom {
  id        String           @id @default(uuid())
  channelId String           @map("channel_id")
  channel   Channel          @relation(fields: [channelId], references: [id], onDelete: Cascade)
  name      String           @default("general")
  messages  ChannelMessage[]
  createdAt DateTime         @default(now()) @db.Timestamptz()
  updatedAt DateTime         @updatedAt @db.Timestamptz()

  @@index([channelId])
  @@map("channel_chat_rooms")
}

model ChannelMessage {
  id         String          @id @default(uuid())
  chatRoomId String          @map("chat_room_id")
  chatRoom   ChannelChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  agentId    String?         @map("agent_id")
  role       String          // "user" | "assistant"
  content    String
  tokens     Int?
  cost       Decimal?        @db.Decimal(12, 6)
  metadata   Json?           @db.JsonB
  createdAt  DateTime        @default(now()) @db.Timestamptz()

  @@index([chatRoomId])
  @@index([agentId])
  @@map("channel_messages")
}

// ─── Workspace Models ───────────────────────────────────────────────────────────

model Workspace {
  id          String            @id @default(uuid())
  channelId   String?           @unique @map("channel_id")
  channel     Channel?          @relation(fields: [channelId], references: [id], onDelete: Cascade)
  ownerId     String            @map("owner_id")
  owner       User              @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  name        String
  slug        String
  description String?
  avatar      String?
  status      String            @default("active") // "active" | "archived" | "deleted"
  members     WorkspaceMember[]
  invites     WorkspaceInvite[]
  memories    WorkspaceMemory[]
  knowledgeBases KnowledgeBase[]
  agents      Agent[]
  createdAt   DateTime          @default(now()) @db.Timestamptz()
  updatedAt   DateTime          @updatedAt @db.Timestamptz()

  @@index([ownerId, status])
  @@index([channelId])
  @@map("workspaces")
}

model WorkspaceMember {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        String    @default("member") // "owner" | "admin" | "member" | "viewer"
  status      String    @default("active") // "active" | "removed"
  joinedAt    DateTime? @map("joined_at") @db.Timestamptz()
  createdAt   DateTime  @default(now()) @db.Timestamptz()
  updatedAt   DateTime  @updatedAt @db.Timestamptz()

  @@unique([workspaceId, userId])
  @@index([workspaceId, status])
  @@index([userId, status])
  @@map("workspace_members")
}

model WorkspaceInvite {
  id              String    @id @default(uuid())
  workspaceId     String    @map("workspace_id")
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  email           String
  emailNormalized String    @map("email_normalized")
  tokenHash       String    @unique @map("token_hash")
  role            String    @default("member") // "admin" | "member" | "viewer"
  status          String    @default("pending") // "pending" | "accepted" | "expired" | "revoked"
  expiresAt       DateTime  @map("expires_at") @db.Timestamptz()
  invitedById     String    @map("invited_by_id")
  invitedBy       User      @relation("InviteSender", fields: [invitedById], references: [id])
  acceptedById    String?   @map("accepted_by_id")
  acceptedAt      DateTime? @map("accepted_at") @db.Timestamptz()
  createdAt       DateTime  @default(now()) @db.Timestamptz()
  updatedAt       DateTime  @updatedAt @db.Timestamptz()

  @@index([workspaceId, status])
  @@index([emailNormalized, status])
  @@map("workspace_invites")
}

model WorkspaceMemory {
  id              String    @id @default(uuid())
  workspaceId     String    @map("workspace_id")
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  type            String    // "fact" | "preference" | "policy" | "context" | "exclusion"
  content         String
  confidence      Float     @default(0.75)
  sourceRunId     String?   @map("source_run_id")
  createdById     String?   @map("created_by_id")
  lastConfirmedAt DateTime  @default(now()) @map("last_confirmed_at") @db.Timestamptz()
  expiresAt       DateTime? @map("expires_at") @db.Timestamptz()
  isPinned        Boolean   @default(false) @map("is_pinned")
  status          String    @default("active") // "active" | "archived" | "deleted"
  createdAt       DateTime  @default(now()) @db.Timestamptz()
  updatedAt       DateTime  @updatedAt @db.Timestamptz()

  @@index([workspaceId, status])
  @@index([workspaceId, type])
  @@map("workspace_memories")
}

// ─── Email Jobs (Outbox) ────────────────────────────────────────────────────────

model EmailJob {
  id                String    @id @default(uuid())
  type              String    // "workspace_invite"
  recipientEmail    String    @map("recipient_email")
  payload           Json
  status            String    @default("pending") // "pending" | "sending" | "sent" | "failed"
  attempts          Int       @default(0)
  lastError         String?   @map("last_error")
  sentAt            DateTime? @map("sent_at") @db.Timestamptz()
  nextAttemptAt     DateTime? @map("next_attempt_at") @db.Timestamptz()
  provider          String?
  providerMessageId String?   @map("provider_message_id")
  createdAt         DateTime  @default(now()) @db.Timestamptz()
  updatedAt         DateTime  @updatedAt @db.Timestamptz()

  @@index([status, nextAttemptAt])
  @@map("email_jobs")
}
