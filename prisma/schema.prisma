generator client {
  provider        = "prisma-client"
  output          = "../apps/api/src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  balance       Decimal        @default(0) @db.Decimal(12, 6)
  apiKey        String         @unique @default(uuid())
  createdAt     DateTime       @default(now()) @db.Timestamptz()
  usageLogs     UsageLog[]
  transactions  Transaction[]
  conversations Conversation[]
  knowledgeBases KnowledgeBase[]
  portalSessions PortalSession[]

  @@map("users")
}

model UsageLog {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  model        String
  inputTokens  Int
  outputTokens Int
  cost         Decimal  @db.Decimal(12, 6)
  latencyMs    Int
  provider     String
  createdAt    DateTime @default(now()) @db.Timestamptz()

  @@index([userId])
  @@index([createdAt])

  @@map("usage_logs")
}

model Transaction {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  amount    Decimal  @db.Decimal(12, 6)
  type      String   // "topup" | "deduction" | "refund"
  status    String   // "pending" | "success" | "failed"
  reference String?  @unique // Stripe/Xendit payment ID
  createdAt DateTime @default(now()) @db.Timestamptz()

  @@index([userId])
  @@index([createdAt])

  @@map("transactions")
}

model AiModel {
  id          String   @id @default(uuid())
  slug        String   @unique
  modelName   String   @map("model_name")
  provider    String
  providerId  String
  inputPrice  Decimal  @db.Decimal(18, 12)
  outputPrice Decimal  @db.Decimal(18, 12)
  maxTokens   Int
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @db.Timestamptz()
  updatedAt   DateTime @updatedAt @db.Timestamptz()

  @@map("ai_models")
}

model AppConfig {
  id    String @id @default(uuid())
  key   String @unique
  value String

  @@map("app_configs")
}

model SystemPrompt {
  id        String   @id @default(uuid())
  name      String   @unique
  content   String
  active    Boolean  @default(true)
  priority  Int      @default(0)
  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()

  @@index([active])
  @@map("system_prompts")
}

model PromptTemplate {
  id           String   @id @default(uuid())
  slug         String   @unique
  name         String
  description  String
  content      String
  keywords     String[] // keywords used for intent matching
  active       Boolean  @default(true)
  priority     Int      @default(0)
  outputFormat String?  @map("output_format") // "pdf" | "docx" | "xlsx" | null
  createdAt    DateTime @default(now()) @db.Timestamptz()
  updatedAt    DateTime @updatedAt @db.Timestamptz()

  @@index([active])
  @@map("prompt_templates")
}

model Conversation {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  title     String?
  model     String
  createdAt DateTime  @default(now()) @db.Timestamptz()
  updatedAt DateTime  @updatedAt @db.Timestamptz()
  messages  Message[]

  @@index([userId])
  @@index([updatedAt])
  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String       // "user" | "assistant" | "system"
  content        String
  documentFormat String?      @map("document_format")
  documentFilename String?    @map("document_filename")
  documentKey    String?      @map("document_key")
  createdAt      DateTime     @default(now()) @db.Timestamptz()

  @@index([conversationId])
  @@map("messages")
}

model KnowledgeBase {
  id          String           @id @default(uuid())
  userId      String?
  user        User?            @relation(fields: [userId], references: [id])
  name        String
  description String?
  isSystem    Boolean          @default(false) @map("is_system")
  active      Boolean          @default(true)
  createdAt   DateTime         @default(now()) @db.Timestamptz()
  updatedAt   DateTime         @updatedAt @db.Timestamptz()
  chunks      KnowledgeChunk[]

  @@index([userId])
  @@map("knowledge_bases")
}

model KnowledgeChunk {
  id              String        @id @default(uuid())
  knowledgeBaseId String
  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  content         String
  metadata        Json?
  embedding       Unsupported("vector(1024)")?
  tokenCount      Int
  createdAt       DateTime      @default(now()) @db.Timestamptz()

  @@index([knowledgeBaseId])
  @@map("knowledge_chunks")
}

model PortalSession {
  id            String    @id @default(uuid())
  sessionToken  String    @unique
  requestCount  Int       @default(0)
  ipAddress     String?
  userId        String?
  user          User?     @relation(fields: [userId], references: [id])
  lastRequestAt DateTime? @db.Timestamptz()
  lastResetAt   DateTime  @default(now()) @db.Timestamptz()
  createdAt     DateTime  @default(now()) @db.Timestamptz()

  @@index([userId])
  @@index([lastResetAt])
  @@index([ipAddress])
  @@map("portal_sessions")
}
